# Telephony Provider (telnyx or twilio)
PROVIDER=telnyx

# Telnyx
TELNYX_API_KEY=KEY_xxx
TELNYX_CONNECTION_ID=xxx
TELNYX_PHONE_NUMBER=+1xxxxxxxxxx
# Webhook signature verification (base64 public key from Telnyx Mission Control)
# TELNYX_PUBLIC_KEY=

# Twilio (future)
# TWILIO_ACCOUNT_SID=xxx
# TWILIO_AUTH_TOKEN=xxx
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Webhook (your public URL for Telnyx to send events to)
WEBHOOK_BASE_URL=https://your-domain.com

# Cloudflare Tunnel (optional — for persistent public URL)
# Get token from: Cloudflare Zero Trust → Tunnels → Create Tunnel
# CLOUDFLARE_TUNNEL_TOKEN=eyJ...

# App
PORT=3000

# Auth — default admin created on first startup
# DEFAULT_ADMIN_PASSWORD=your-secure-password-here
# DEFAULT_ADMIN_EMAIL=admin@localhost
# REQUIRE_MFA=false

# WorkOS SSO — optional, for Google/GitHub/SAML login
# Sign up at https://workos.com, create an app, get your keys
# WORKOS_API_KEY=
# WORKOS_CLIENT_ID=

# Transcript retention (days) — set to 0 to keep forever
# TRANSCRIPT_RETENTION_DAYS=30

# Database
# Local SQLite (default):
DATABASE_URL=./data/opendialer.db
# External libSQL (remote):
# DATABASE_URL=libsql://your-db.example.com
# DATABASE_AUTH_TOKEN=your-token-here
